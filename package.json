{
  "name": "harness-engineer",
  "version": "0.2.1",
  "description": "Open-source Codex-first scaffolding CLI for file-first harness engineering workflows.",
  "keywords": [
    "codex",
    "cli",
    "scaffold",
    "harness",
    "agent",
    "orchestration",
    "workflow",
    "documentation",
    "plans"
  ],
  "homepage": "https://github.com/Dai5297/harness-engineer-codex#readme",
  "bugs": {
    "url": "https://github.com/Dai5297/harness-engineer-codex/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dai5297/harness-engineer-codex.git"
  },
  "license": "MIT",
  "author": "dai",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "harness-engineer": "dist/cli.js"
  },
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test && pnpm build",
    "release:check": "pnpm typecheck && pnpm test && pnpm build && pnpm pack",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.28.2"
}
