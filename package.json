{
  "name": "harness-engineer",
  "version": "0.2.3",
  "description": "Scaffold repository-owned harness engineering docs, execution plans, and agent collaboration guides.",
  "keywords": [
    "codex",
    "cli",
    "scaffold",
    "harness",
    "agent",
    "orchestration",
    "workflow",
    "documentation",
    "plans",
    "typescript",
    "harness-engineering"
  ],
  "homepage": "https://github.com/Dai5297/harness-engineer-codex#readme",
  "bugs": {
    "url": "https://github.com/Dai5297/harness-engineer-codex/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dai5297/harness-engineer-codex.git"
  },
  "license": "MIT",
  "author": "dai",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "harness": "dist/cli.js"
  },
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm typecheck && pnpm test",
    "clean": "node -e \"const fs = require('node:fs'); for (const path of ['dist', 'coverage']) fs.rmSync(path, { recursive: true, force: true });\"",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm check && pnpm build",
    "release:check": "pnpm check && pnpm test:coverage && pnpm build && pnpm pack",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.28.2"
}
