{
  "name": "harness-engineer",
  "version": "0.1.0",
  "description": "Open-source Codex harness scaffolding CLI for repository-owned orchestration workflows.",
  "keywords": [
    "codex",
    "cli",
    "scaffold",
    "agent",
    "orchestration",
    "workflow"
  ],
  "homepage": "https://github.com/Dai5297/harness-engineer-codex#readme",
  "bugs": {
    "url": "https://github.com/Dai5297/harness-engineer-codex/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dai5297/harness-engineer-codex.git"
  },
  "license": "MIT",
  "author": "dai",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "index.js",
  "bin": {
    "harness-engineer": "dist/cli.js"
  },
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test && pnpm build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.28.2"
}
