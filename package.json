{
  "name": "harness-engineer",
  "version": "0.1.0",
  "description": "Source-available Codex harness scaffolding CLI for repository-owned orchestration workflows.",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "bin": {
    "harness-engineer": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE.md",
    "LICENSE.zh-CN.md",
    "COMMERCIAL-LICENSING.md"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "codex",
    "cli",
    "scaffold",
    "agent",
    "orchestration",
    "workflow"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test && pnpm build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
